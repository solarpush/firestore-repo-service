{
    "functions": {
        "source": "test/functions",
        "codebase": "default",
        "runtime": "nodejs22",
        "ignore": [
            "node_modules",
            ".git",
            "firebase-debug.log",
            "firebase-debug.*.log",
            ".cache",
            "*.ts",
            "tsconfig.json"
        ],
        "predeploy": [
            "npm --prefix \"$RESOURCE_DIR\" run build"
        ]
    },
    "emulators": {
        "functions": {
            "host": "127.0.0.1",
            "port": 5001
        },
        "firestore": {
            "host": "127.0.0.1",
            "port": 8080
        },
        "pubsub": {
            "host": "127.0.0.1",
            "port": 8085
        },
        "ui": {
            "enabled": true,
            "port": 4000
        }
    }
}